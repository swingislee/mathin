NEXT_PUBLIC_SITE_URL=http://192.168.5.213:3130
# 局域网开发时，双击项目根目录 Supabase路由切换.cmd 选择 LAN direct，
# 使此域名直接解析至 Xiaomi Caddy，并为后续 Shell 添加 NO_PROXY 绕过规则；
# 选择 Public Internet 则测试完整公网链路。切换后需重新打开终端。
NEXT_PUBLIC_SUPABASE_URL=https://supabase.mathin.club
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
# 仅服务端（Server Actions）使用，绕过 RLS 做受信写入；绝不能带 NEXT_PUBLIC_ 前缀
SUPABASE_SECRET_KEY=replace-with-your-secret-key

# 可选的服务端错误看板接收端。生产环境只接受 HTTPS；token 仅服务端读取。
# 接收 JSON：event/message/digest/path/method/routeType/environment/release。
MATHIN_ERROR_REPORT_URL=
MATHIN_ERROR_REPORT_TOKEN=
MATHIN_RELEASE=

# 课堂 T1 局域网直连的 ICE 服务器（P4-6）。浏览器会把 host 候选混淆成 mDNS，
# 跨设备（手机↔电脑）常解析不了；局域网内的 coturn 通过 STUN 返回真实局域网
# 地址（srflx）绕开该问题，TURN 兜底 AP 隔离。不配则回落公网 STUN（国内不可靠）。
NEXT_PUBLIC_WEBRTC_STUN=stun:192.168.5.183:3478
NEXT_PUBLIC_WEBRTC_TURN=turn:192.168.5.183:3478?transport=udp
NEXT_PUBLIC_WEBRTC_TURN_USER=mathin
NEXT_PUBLIC_WEBRTC_TURN_PASS=replace-with-coturn-password
