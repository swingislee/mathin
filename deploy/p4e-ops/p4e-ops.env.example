# BACKUP_ROOT 必须位于 NAS/异机挂载点；脚本默认拒绝把“生产备份”写到系统盘。
BACKUP_ROOT=/mnt/mathin-backup
STORAGE_DIR=/home/swing/services/supabase-project/volumes/storage
DB_CONTAINER=supabase-db
DB_NAME=postgres
DB_USER=postgres
RETENTION_DAYS=30
WARN_PERCENT=75
CRITICAL_PERCENT=85
MAX_BACKUP_AGE_HOURS=26

# 企业微信/飞书等接受 {"text":"..."} 的机器人地址。该文件部署到 /etc/mathin 后权限设为 0600。
ALERT_WEBHOOK_URL=
